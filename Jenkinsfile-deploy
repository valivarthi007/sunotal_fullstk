pipeline {
  agent any

  environment {
    NODE_VERSION = '20'
    PNPM_VERSION = '9.15.4'
    AWS_CREDS = credentials('AWS')
    AWS_DEFAULT_REGION = 'us-east-1'
  }

  options {
    timestamps()
    timeout(time: 60, unit: 'MINUTES')
    skipDefaultCheckout(false)
  }

  triggers {
    githubPush()
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install tools') {
      steps {
        sh '''
          node --version
          npx pnpm@${PNPM_VERSION} --version
        '''
      }
    }

    stage('Install frontend dependencies') {
      steps {
        dir('frontend') {
          sh 'npx pnpm@${PNPM_VERSION} install --frozen-lockfile'
        }
      }
    }

    stage('Lint and type-check frontend') {
      steps {
        dir('frontend') {
          sh 'npx pnpm@${PNPM_VERSION} exec tsc --noEmit'
        }
      }
    }

    stage('Build frontend') {
      steps {
        dir('frontend') {
          sh 'npx pnpm@${PNPM_VERSION} build'
        }
      }
    }

    stage('Install backend dependencies') {
      steps {
        dir('backend') {
          sh 'npx pnpm@${PNPM_VERSION} install --frozen-lockfile'
        }
      }
    }

    stage('Build backend') {
      steps {
        dir('backend') {
          sh 'npx pnpm@${PNPM_VERSION} build'
        }
      }
    }

    stage('Package artifacts') {
      steps {
        sh '''
          mkdir -p dist/artifacts
          tar -czf dist/artifacts/frontend-build.tgz -C frontend dist
          tar -czf dist/artifacts/backend-build.tgz -C backend dist package.json
        '''
      }
    }

    stage('Deploy to EC2') {
      steps {
        withCredentials([sshUserPrivateKey(credentialsId: 'EC2_SSH_KEY', keyFileVariable: 'SSH_KEY', usernameVariable: 'SSH_USER')]) {
          sh '''
            if ! command -v aws >/dev/null 2>&1; then
              echo 'AWS CLI is not installed. Please install it on the Jenkins agent.'
              exit 1
            fi
            
            export AWS_ACCESS_KEY_ID=$AWS_CREDS_USR
            export AWS_SECRET_ACCESS_KEY=$AWS_CREDS_PSW
            
            # Find the running EC2 instance by its tag
            EC2_IP=$(aws ec2 describe-instances --region us-east-1 \\
              --filters "Name=tag:Name,Values=sunotal-frontend" "Name=instance-state-name,Values=running" \\
              --query "Reservations[*].Instances[*].PublicIpAddress" --output text)
            
            if [ -z "$EC2_IP" ] || [ "$EC2_IP" == "None" ]; then
              echo "Failed to get EC2 IP address from AWS. Make sure the instance is running."
              exit 1
            fi
            
            echo "Deploying to EC2 instance at $EC2_IP"
            
            # Deploy frontend to Nginx directory
            rsync -avz -e "ssh -i $SSH_KEY -o StrictHostKeyChecking=no" frontend/dist/ ubuntu@$EC2_IP:/var/www/sunotal/
            
            # Deploy database config (docker-compose)
            scp -i $SSH_KEY -o StrictHostKeyChecking=no docker-compose.yml ubuntu@$EC2_IP:/home/ubuntu/
            ssh -i $SSH_KEY -o StrictHostKeyChecking=no ubuntu@$EC2_IP "docker compose up -d"
            
            # Deploy backend
            rsync -avz -e "ssh -i $SSH_KEY -o StrictHostKeyChecking=no" --exclude 'node_modules' backend/ ubuntu@$EC2_IP:/var/www/sunotal-backend/
            ssh -i $SSH_KEY -o StrictHostKeyChecking=no ubuntu@$EC2_IP "cd /var/www/sunotal-backend && cp -n .env.example .env && npx pnpm@${PNPM_VERSION} install --prod && npx pnpm@${PNPM_VERSION} run db:push && pm2 start dist/index.js --name sunotal-backend --update-env || pm2 restart sunotal-backend"
          '''
        }
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'dist/artifacts/**', allowEmptyArchive: true
      junit allowEmptyResults: true, testResults: 'reports/**/*.xml'
    }
    success {
      echo 'Application deployed successfully.'
    }
    failure {
      echo 'Deployment pipeline failed.'
    }
  }
}
