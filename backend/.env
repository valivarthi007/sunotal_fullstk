# ── Database ─────────────────────────────────────────────────────────────────
# If you used docker-compose to start PostgreSQL, this default works as-is.
DATABASE_URL=postgresql://sunotal:sunotalpass123@127.0.0.1:5432/sunotal

# ── Auth ──────────────────────────────────────────────────────────────────────
# IMPORTANT: change this to a long random string before deploying to production!
# Generate one with:  openssl rand -hex 64
JWT_SECRET=sunotal-change-this-secret-before-deploying-to-production

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────────────────
# Origin of the frontend (used for CORS allow-list)
FRONTEND_URL=http://localhost:3000
